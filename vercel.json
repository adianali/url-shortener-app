{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/backend/api/index.js" },
    { "source": "/docs/:path*",      "destination": "/backend/api/index.js" },
    { "source": "/health",           "destination": "/backend/api/index.js" },
    { "source": "/login",            "destination": "/index.html" },
    { "source": "/register",         "destination": "/index.html" },
    { "source": "/dashboard",        "destination": "/index.html" },
    { "source": "/dashboard/:path*", "destination": "/index.html" },
    { "source": "/settings",         "destination": "/index.html" },
    { "source": "/settings/:path*",  "destination": "/index.html" },
    { "source": "/:slug",            "destination": "/backend/api/index.js" }
  ]
}
